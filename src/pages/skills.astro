---
import Layout from '../layouts/Layout.astro';

const languages = [
  { name: "Java", level: "Advanced",     pct: 90 },
  { name: "Kotlin", level: "Advanced",   pct: 88 },
  { name: "C++", level: "Advanced",      pct: 78 },
  { name: "JavaScript", level: "Intermediate", pct: 78 },
  { name: "PHP", level: "Intermediate",  pct: 72 },
  { name: "SQL", level: "Advanced",      pct: 85 },
  { name: "HTML / CSS", level: "Intermediate", pct: 80 },
  { name: "C", level: "Intermediate",    pct: 65 },
];

const tools = [
  "Android Studio", "MySQL", "Oracle APEX", "Apache Tomcat",
  "VS Code", "GitHub", "jQuery", "Oracle SQL Developer",
  "ArcGIS / Esri", "Firebase", "TensorFlow", "Anaconda"
];

const qualities = [
  { icon: "🤝", name: "Team Player",    desc: "Thrives in collaborative environments, values shared success." },
  { icon: "🧭", name: "Leadership",     desc: "Takes initiative in guiding projects and teams." },
  { icon: "🔍", name: "Problem Solver", desc: "Analytical thinker who enjoys tackling complex challenges." },
  { icon: "✅", name: "Responsible",    desc: "Reliable and accountable, consistently delivers on commitments." },
  { icon: "⚡", name: "Fast Learner",   desc: "Quickly adapts to new technologies and methodologies." },
  { icon: "💡", name: "Creative",       desc: "Approaches design and development with an eye for quality UX." },
];
---
<Layout title="Skills · CJJ">
<div class="page-section">

  <h1 class="page-title fade-up">Skills & Qualities</h1>
  <p class="page-subtitle fade-up">What I bring to the table</p>

  <!-- Certifications banner -->
  <div class="certs-row fade-up">
    <div class="glass cert-chip">
      <span class="cert-icon">🏅</span>
      <div>
        <p class="cert-title">Oracle DB Foundations – Junior Associate</p>
        <p class="cert-sub">September 2025</p>
      </div>
    </div>
    <div class="glass cert-chip">
      <span class="cert-icon">🗺</span>
      <div>
        <p class="cert-title">GIS Basics Certificate – Esri Training</p>
        <p class="cert-sub">March 2026</p>
      </div>
    </div>
  </div>

  <!-- Languages with bars -->
  <h2 class="section-h2 fade-up delay-1">Programming Languages</h2>
  <div class="glass skill-bars fade-up delay-1">
    {languages.map(l => (
      <div class="skill-row">
        <div class="skill-meta">
          <span class="skill-name">{l.name}</span>
          <span class="skill-level">{l.level}</span>
        </div>
        <div class="bar-track">
          <div class="bar-fill" style={`width: ${l.pct}%`}></div>
        </div>
      </div>
    ))}
  </div>

  <!-- Tools -->
  <h2 class="section-h2 fade-up delay-2">Tools & Technologies</h2>
  <div class="tools-wrap fade-up delay-2">
    {tools.map(t => <span class="tag">{t}</span>)}
  </div>

  <!-- Qualities -->
  <h2 class="section-h2 fade-up delay-3">Personal Qualities</h2>
  <div class="qualities-grid fade-up delay-3">
    {qualities.map(q => (
      <div class="glass quality-card">
        <span class="q-icon">{q.icon}</span>
        <h3>{q.name}</h3>
        <p>{q.desc}</p>
      </div>
    ))}
  </div>

</div>
</Layout>

<style>
  .certs-row { display: flex; gap: 1rem; flex-wrap: wrap; margin-bottom: 2.5rem; }
  .cert-chip { display: flex; align-items: center; gap: 1rem; flex: 1; min-width: 260px; }
  .cert-icon { font-size: 2rem; flex-shrink: 0; }
  .cert-title { font-size: 0.9rem; font-weight: 600; color: #fff; }
  .cert-sub   { font-size: 0.78rem; color: var(--accent); margin-top: 2px; }

  .section-h2 { font-size: 1.4rem; font-weight: 700; color: #fff; margin: 2rem 0 1rem; }

  /* Skill bars */
  .skill-bars { display: flex; flex-direction: column; gap: 1.1rem; margin-bottom: 2rem; }
  .skill-row  { display: flex; flex-direction: column; gap: 6px; }
  .skill-meta { display: flex; justify-content: space-between; }
  .skill-name { font-size: 0.9rem; font-weight: 600; color: #fff; }
  .skill-level{ font-size: 0.78rem; color: var(--accent); }
  .bar-track  { height: 6px; background: rgba(255,255,255,0.08); border-radius: 999px; overflow: hidden; }
  .bar-fill   {
    height: 100%; border-radius: 999px;
    background: linear-gradient(90deg, var(--accent), var(--accent2));
    animation: growBar 1s ease both;
  }
  @keyframes growBar { from { width: 0 !important; } }

  /* Tools */
  .tools-wrap { display: flex; flex-wrap: wrap; gap: 0.6rem; margin-bottom: 2rem; }

  /* Qualities */
  .qualities-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px,1fr)); gap: 1.2rem; }
  .quality-card { text-align: center; transition: transform 0.2s; }
  .quality-card:hover { transform: translateY(-4px); }
  .q-icon { font-size: 2rem; display: block; margin-bottom: 0.6rem; }
  .quality-card h3 { font-size: 1rem; font-weight: 700; color: #fff; margin-bottom: 0.4rem; }
  .quality-card p  { font-size: 0.85rem; color: var(--muted); line-height: 1.5; }
</style>
