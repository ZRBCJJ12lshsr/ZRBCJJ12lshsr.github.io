---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;
---
<Layout title="CJJ · Portfolio">

  <!-- Hero -->
  <section class="hero">
    <div class="hero-video-wrap">
      <video autoplay muted loop playsinline class="hero-video">
        <source src="https://cdn.coverr.co/videos/coverr-purple-and-pink-abstract-background-9601/1080p.mp4" type="video/mp4" />
      </video>
      <div class="hero-overlay"></div>
    </div>

    <div class="hero-content fade-up">
      <div class="hero-chip">👋 Available for Internship · 2026</div>
      <h1 class="hero-name">CHAI<br/><span class="name-accent">JIAN JIE</span></h1>
      <p class="hero-role">
        Software Development Student
        <span class="role-sep">·</span>
        <span class="role-uni">UTeM</span>
      </p>
      <p class="hero-desc">
        Building mobile apps, distributed systems & web applications.<br/>
        Passionate about clean code and user-centered design.
      </p>
      <div class="hero-cta">
        <a href={`${base}projects`} class="btn-glow">View Projects</a>
        <a href={`${base}contact`} class="btn-outline">Contact Me</a>
        <a href={`${base}resume.pdf`} download class="btn-outline btn-resume">⬇ Resume</a>
      </div>
      <div class="hero-stats">
        <div class="hstat">
          <span class="icon-badge hstat-badge">🎓</span>
          <span class="hstat-n">3.58</span>
          <span class="hstat-l">CGPA</span>
        </div>
        <div class="hstat-div"></div>
        <div class="hstat">
          <span class="icon-badge hstat-badge">📁</span>
          <span class="hstat-n">6+</span>
          <span class="hstat-l">Projects</span>
        </div>
        <div class="hstat-div"></div>
        <div class="hstat">
          <span class="icon-badge hstat-badge">🏅</span>
          <span class="hstat-n">2</span>
          <span class="hstat-l">Certs</span>
        </div>
      </div>
    </div>

  </section>

  <!-- Quick cards -->
  <section class="cards-section">
    <div class="cards-grid">
      {[
        { icon: "👤", title: "About Me",  desc: "From Perak, now in KL. Love gaming, badminton & building things.", href: `${base}about`,    cta: "Learn more" },
        { icon: "⚡", title: "Skills",    desc: "Java, Kotlin, C++, JS, PHP, SQL — and growing.", href: `${base}skills`,   cta: "View skills" },
        { icon: "🗂", title: "Projects",  desc: "Mobile apps, distributed systems, AI & databases.", href: `${base}projects`, cta: "See projects" },
        { icon: "📄", title: "Academic",  desc: "Year 3 at UTeM — Oracle certified, GIS certified.", href: `${base}academic`, cta: "See history" },
      ].map(c => (
        <a href={c.href} class="quick-card glass reveal">
          <div class="qc-icon"><span class="icon-badge">{c.icon}</span></div>
          <h3>{c.title}</h3>
          <p>{c.desc}</p>
          <span class="qc-cta">{c.cta} →</span>
        </a>
      ))}
    </div>
  </section>

</Layout>

<style>
/* ── Hero ── */
.hero {
  position: relative; height: 100svh; min-height: 640px;
  display: flex; align-items: center; justify-content: center; overflow: hidden;
}
.hero-video-wrap { position: absolute; inset: 0; z-index: 0; }
.hero-video { width: 100%; height: 100%; object-fit: cover; opacity: 0.25; }
.hero-overlay {
  position: absolute; inset: 0;
  background: linear-gradient(to bottom, rgba(5,13,21,0.55) 0%, rgba(5,13,21,0.92) 100%);
}

.hero-content { position: relative; z-index: 1; text-align: center; padding: 2rem; max-width: 700px; }

.hero-chip {
  display: inline-block; padding: 0.35rem 1.1rem; border-radius: 999px;
  border: 1px solid var(--border); color: var(--cyan); font-size: 0.8rem; font-weight: 600;
  background: rgba(0,191,165,0.08); margin-bottom: 1.5rem;
  box-shadow: 0 0 16px var(--glow-sm);
}

.hero-name {
  font-size: clamp(3rem, 10vw, 6.5rem); font-weight: 800; line-height: 1;
  letter-spacing: 4px; color: #fff; margin-bottom: 0.6rem;
  text-shadow: 0 0 60px rgba(0,191,165,0.15);
}
.name-accent {
  background: linear-gradient(135deg, var(--cyan) 0%, var(--blue) 100%);
  -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
  filter: drop-shadow(0 0 20px var(--glow));
}

.hero-role {
  font-size: 1rem; color: var(--muted); letter-spacing: 2px; margin-bottom: 1rem;
}
.role-sep { margin: 0 0.5rem; }
.role-uni { color: var(--cyan); font-weight: 600; }

.hero-desc { font-size: 0.95rem; color: var(--muted); line-height: 1.75; margin-bottom: 2rem; }

.hero-cta { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; margin-bottom: 2.5rem; }
.btn-resume { border-color: rgba(0,191,165,0.4); color: var(--cyan); font-size: 0.88rem; }
.btn-resume:hover { background: rgba(0,191,165,0.08); }

.hero-stats { display: flex; align-items: center; justify-content: center; gap: 1.5rem; }
.hstat { display: flex; flex-direction: column; align-items: center; gap: 0.3rem; }
.hstat-badge { width: 44px; height: 44px; border-radius: 12px; font-size: 1.3rem; }
.hstat-n { font-size: 1.5rem; font-weight: 800; color: var(--cyan); line-height: 1; text-shadow: 0 0 20px var(--glow); }
.hstat-l { font-size: 0.68rem; color: var(--muted); text-transform: uppercase; letter-spacing: 1px; }
.hstat-div { width: 1px; height: 40px; background: var(--border); }


/* ── Cards ── */
.cards-section { max-width: 960px; margin: 0 auto; padding: 5rem 2rem; }
.cards-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1.2rem; }

.quick-card {
  display: flex; flex-direction: column; text-decoration: none; color: inherit;
  cursor: pointer; transition: transform 0.3s, box-shadow 0.3s, border-color 0.3s;
}
.quick-card:hover {
  transform: translateY(-8px);
  box-shadow: 0 0 40px var(--glow-sm), 0 20px 40px rgba(0,0,0,0.4);
  border-color: var(--cyan);
}
.qc-icon { margin-bottom: 1rem; }
.quick-card h3 { font-size: 1.05rem; font-weight: 700; color: #fff; margin-bottom: 0.4rem; }
.quick-card p  { font-size: 0.86rem; color: var(--muted); line-height: 1.6; flex: 1; margin-bottom: 1rem; }
.qc-cta { font-size: 0.82rem; font-weight: 700; color: var(--cyan); }
</style>
