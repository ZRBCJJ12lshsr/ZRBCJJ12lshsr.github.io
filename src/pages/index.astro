---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;
---
<Layout title="CJJ · Portfolio">

  <!-- Hero -->
  <section class="hero">
    <div class="hero-bg">
      <video autoplay muted loop playsinline class="hero-video">
        <source src="https://cdn.coverr.co/videos/coverr-purple-and-pink-abstract-background-9601/1080p.mp4" type="video/mp4" />
      </video>
      <div class="hero-overlay"></div>
    </div>

    <div class="hero-content fade-up">
      <p class="hero-eyebrow">Hello, I'm</p>
      <h1 class="hero-name">CHAI JIAN JIE</h1>
      <p class="hero-handle">@CJJ</p>
      <p class="hero-sub">
        Software Development Student at<br/>
        <span class="hero-uni">Universiti Teknikal Malaysia Melaka (UTeM)</span>
      </p>
      <div class="hero-cta">
        <a href={`${base}projects`} class="btn-primary">View Projects</a>
        <a href={`${base}contact`} class="btn-ghost">Contact Me</a>
      </div>
    </div>

    <div class="hero-scroll">↓</div>
  </section>

  <!-- Quick cards -->
  <section class="cards-section">
    <div class="cards-grid">
      <div class="quick-card glass fade-up delay-1">
        <div class="qc-icon">👤</div>
        <h3>About Me</h3>
        <p>Student from Perak, now in KL. Love gaming, badminton, and teamwork.</p>
        <a href={`${base}about`}>Learn more →</a>
      </div>
      <div class="quick-card glass fade-up delay-2">
        <div class="qc-icon">⚡</div>
        <h3>Skills</h3>
        <p>Java, Kotlin, C++, JavaScript, PHP, SQL. Problem solver and fast learner.</p>
        <a href={`${base}skills`}>View skills →</a>
      </div>
      <div class="quick-card glass fade-up delay-3">
        <div class="qc-icon">🗂</div>
        <h3>Projects</h3>
        <p>Mobile apps, distributed systems, databases, and AI applications.</p>
        <a href={`${base}projects`}>See projects →</a>
      </div>
    </div>
  </section>

</Layout>

<style>
  /* ── Hero ── */
  .hero {
    position: relative; height: 100vh; min-height: 600px;
    display: flex; align-items: center; justify-content: center;
    overflow: hidden;
  }
  .hero-bg { position: absolute; inset: 0; z-index: 0; }
  .hero-video { width: 100%; height: 100%; object-fit: cover; opacity: 0.35; }
  .hero-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to bottom, rgba(10,10,20,0.4) 0%, rgba(10,10,20,0.85) 100%);
  }

  .hero-content {
    position: relative; z-index: 1; text-align: center; padding: 2rem;
  }
  .hero-eyebrow {
    color: var(--muted); font-size: 0.95rem; letter-spacing: 3px;
    text-transform: uppercase; margin-bottom: 0.5rem;
  }
  .hero-name {
    font-size: clamp(2.5rem, 8vw, 5.5rem); font-weight: 800; letter-spacing: 4px;
    background: linear-gradient(135deg, #fff 30%, var(--accent) 70%, var(--accent2) 100%);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
    line-height: 1.1; margin-bottom: 0.4rem;
  }
  .hero-handle {
    color: var(--accent); font-size: 1rem; letter-spacing: 4px;
    text-transform: uppercase; margin-bottom: 1.2rem;
  }
  .hero-sub { color: var(--muted); font-size: 1rem; line-height: 1.7; margin-bottom: 2rem; }
  .hero-uni { color: var(--teal); font-weight: 600; }

  .hero-cta { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }
  .btn-primary {
    padding: 0.75rem 2rem; border-radius: 999px; text-decoration: none;
    background: linear-gradient(135deg, var(--accent), var(--accent2));
    color: #fff; font-weight: 600; font-size: 0.9rem;
    transition: opacity 0.2s, transform 0.2s;
  }
  .btn-primary:hover { opacity: 0.9; transform: translateY(-2px); }
  .btn-ghost {
    padding: 0.75rem 2rem; border-radius: 999px; text-decoration: none;
    border: 1px solid var(--border); color: var(--text); font-weight: 600; font-size: 0.9rem;
    backdrop-filter: blur(8px); transition: background 0.2s, transform 0.2s;
  }
  .btn-ghost:hover { background: var(--card); transform: translateY(-2px); }

  .hero-scroll {
    position: absolute; bottom: 2rem; left: 50%; transform: translateX(-50%);
    color: var(--muted); font-size: 1.2rem; animation: bounce 2s infinite; z-index: 1;
  }
  @keyframes bounce {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50%       { transform: translateX(-50%) translateY(8px); }
  }

  /* ── Cards ── */
  .cards-section { max-width: 960px; margin: 0 auto; padding: 4rem 2rem; }
  .cards-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 1.5rem; }
  .quick-card { transition: transform 0.25s, box-shadow 0.25s; }
  .quick-card:hover { transform: translateY(-6px); box-shadow: 0 16px 40px rgba(167,139,250,0.15); }
  .qc-icon { font-size: 2rem; margin-bottom: 0.75rem; }
  .quick-card h3 { font-size: 1.15rem; font-weight: 700; margin-bottom: 0.5rem; color: #fff; }
  .quick-card p  { color: var(--muted); font-size: 0.9rem; line-height: 1.6; margin-bottom: 1rem; }
  .quick-card a  { color: var(--accent); font-size: 0.88rem; font-weight: 600; text-decoration: none; }
  .quick-card a:hover { text-decoration: underline; }
</style>
