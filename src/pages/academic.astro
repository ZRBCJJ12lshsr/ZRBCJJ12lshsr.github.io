---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Academic · CJJ">
<div class="page-section">

  <h1 class="page-title reveal">Academic History</h1>
  <p class="page-subtitle reveal">My educational journey</p>

  <div class="timeline">
    <!-- UTeM -->
    <div class="timeline-item current reveal-left">
      <div class="tl-dot"></div>
      <div class="glass tl-card">
        <span class="tl-badge current-badge">Current</span>
        <h2>Universiti Teknikal Malaysia Melaka (UTeM)</h2>
        <p class="tl-degree">Bachelor of Computer Science (Software Development) with Honours</p>
        <p class="tl-meta">Programme: BITS S1G2 · Year 3 · In Progress</p>
        <p class="tl-desc">
          Pursuing a comprehensive software engineering education with focus on mobile development,
          distributed systems, database design, and emerging technologies. Actively engaged in
          projects combining technical skills with user-centered design principles.
        </p>
        <div class="cgpa-badge">CGPA <strong>3.58</strong></div>
      </div>
    </div>

    <!-- KTEPJ -->
    <div class="timeline-item reveal-right">
      <div class="tl-dot"></div>
      <div class="glass tl-card">
        <span class="tl-badge done-badge">Completed</span>
        <h2>Kolej Tingkatan Enam Pudu Jaya (KTEPJ)</h2>
        <p class="tl-degree">Pre-University (Form 6)</p>
        <p class="tl-meta">Foundation Studies · Completed 2022</p>
        <p class="tl-desc">
          Completed pre-university education with a strong foundation in mathematics and sciences,
          preparing for tertiary education in technology and engineering fields.
        </p>
        <p class="tl-desc">SPM Result: Kepujian Tertinggi</p>
      </div>
    </div>
  </div>

  <!-- Coursework -->
  <h2 class="section-h2 reveal-left">Relevant Coursework</h2>
  <div class="course-grid">
    {[
      { emoji: "💻", title: "Programming & Development", items: ["Programming Fundamentals (C++)", "Object-Oriented Programming (Java)", "Mobile Application Development (Kotlin)", "Distributed Application Development", "Web Application Development"] },
      { emoji: "🗄", title: "Database & Systems",         items: ["Database Introduction", "Database Design", "Oracle DB Foundations (Cert.)", "Operating Systems", "Data Communication & Networking"] },
      { emoji: "🧮", title: "Mathematics & Logic",        items: ["Linear Algebra & Matrices", "Numerical Methods", "Statistics & Probability", "Data Structures & Algorithms", "Algorithm Analysis"] },
      { emoji: "🤖", title: "AI & Design",                items: ["Artificial Intelligence", "Human-Computer Interaction", "Interactive Media Authoring", "Geographic Information Systems"] },
      { emoji: "📋", title: "Professional Skills",        items: ["Software Requirements & Design", "Software Verification & Validation", "Software Project Management", "IT Security", "Technology Entrepreneurship"] },
    ].map((g, i) => (
      <div class={`glass course-card reveal d${(i % 4) + 1}`}>
        <div class="cat-header">
          <span class="icon-badge cat-icon">{g.emoji}</span>
          <h3>{g.title}</h3>
        </div>
        <ul>
          {g.items.map(item => <li>{item}</li>)}
        </ul>
      </div>
    ))}
  </div>

</div>
</Layout>

<style>
  .timeline { position: relative; margin-bottom: 3rem; }
  .timeline::before {
    content: ''; position: absolute; left: 16px; top: 0; bottom: 0;
    width: 2px; background: linear-gradient(to bottom, var(--cyan), var(--blue));
    opacity: 0.45;
  }
  .timeline-item {
    position: relative; padding-left: 52px; margin-bottom: 2rem;
    isolation: isolate;
  }
  .tl-dot {
    position: absolute; left: 8px; top: 24px;
    width: 16px; height: 16px; border-radius: 50%;
    background: linear-gradient(135deg, var(--cyan), var(--blue));
    border: 3px solid var(--bg); z-index: 2;
    box-shadow: 0 0 10px rgba(0,191,165,0.5);
  }
  .tl-badge {
    display: inline-block; padding: 0.2rem 0.8rem; border-radius: 999px;
    font-size: 0.72rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: 1px; margin-bottom: 0.6rem;
  }
  .current-badge { background: rgba(0,191,165,0.14); color: var(--cyan);  border: 1px solid rgba(0,191,165,0.35); }
  .done-badge    { background: rgba(14,165,233,0.12); color: var(--blue);  border: 1px solid rgba(14,165,233,0.30); }

  .tl-card h2    { font-size: 1.15rem; font-weight: 700; color: #fff; margin-bottom: 0.3rem; }
  .tl-degree     { color: var(--cyan); font-size: 0.9rem; font-weight: 600; margin-bottom: 0.2rem; }
  .tl-meta       { color: var(--muted); font-size: 0.8rem; margin-bottom: 0.6rem; }
  .tl-desc       { color: var(--muted); font-size: 0.88rem; line-height: 1.7; margin-bottom: 0.4rem; }
  .cgpa-badge {
    display: inline-block; margin-top: 0.8rem;
    background: rgba(0,191,165,0.10); border: 1px solid rgba(0,191,165,0.30);
    padding: 0.3rem 1rem; border-radius: 999px;
    color: var(--muted); font-size: 0.85rem;
  }
  .cgpa-badge strong { color: var(--cyan); font-size: 1.1rem; }

  .section-h2 { font-size: 1.5rem; font-weight: 700; color: #fff; margin-bottom: 1.2rem; }

  .course-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px,1fr)); gap: 1.2rem; }

  /* Category header with icon badge */
  .cat-header {
    display: flex; align-items: center; gap: 0.9rem; margin-bottom: 1rem;
  }
  .cat-icon { width: 44px; height: 44px; border-radius: 12px; font-size: 1.4rem; flex-shrink: 0; }
  .cat-header h3 { font-size: 0.88rem; font-weight: 700; color: var(--cyan); line-height: 1.3; }

  .course-card ul { list-style: none; padding: 0; }
  .course-card li {
    color: var(--muted); font-size: 0.85rem; padding: 0.25rem 0;
    border-bottom: 1px solid var(--border);
  }
  .course-card li:last-child { border-bottom: none; }
  .course-card li::before { content: "▸ "; color: var(--cyan); }
</style>
