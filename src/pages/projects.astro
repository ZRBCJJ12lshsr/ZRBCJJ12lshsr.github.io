---
import Layout from '../layouts/Layout.astro';

const projects = [
  {
    title: "FinSave",
    type: "Individual Project · Mobile App Development",
    image: "",
    problem: "Tracking personal finances manually is error-prone and inconvenient for students managing limited budgets.",
    solution: "A native Android personal finance tracker built with Kotlin and Android Studio, featuring expense logging, budget management, and transaction history with SQLite local storage.",
    tags: ["Kotlin", "Android Studio", "SQLite", "MVVM", "Material Design"],
    role: ["Designed the app architecture using MVVM pattern", "Built UI screens following Material Design guidelines", "Implemented local SQLite database for data persistence", "Created budget tracking and expense categorisation features"],
    demo: "",
  },
  {
    title: "FoodSmartAI",
    type: "Individual Project · Mobile App Development",
    image: "",
    problem: "Grocery shopping lacks intelligent assistance to help users plan purchases efficiently.",
    solution: "A smart shopping feature module for Android built with MVVM architecture in Kotlin, complete with Data Flow Diagrams and technical architecture documentation.",
    tags: ["Kotlin", "Android", "MVVM", "DFD", "Architecture Design"],
    role: ["Architected the feature using MVVM for clean separation of concerns", "Produced Data Flow Diagrams documenting the data pipeline", "Implemented shopping list management with local persistence"],
    demo: "",
  },
  {
    title: "Save The Princess!",
    type: "Individual Project · Workshop I",
    image: "https://i.imgur.com/64g05Ih.jpg",
    problem: "Many beginner-level games lack structured gameplay progression and proper data management.",
    solution: "A turn-based C++ mini-game where players control a knight to defeat enemies and rescue a princess, with player registration, turn-based combat, multiple stages, a gear/stat system, and game progress stored in a database.",
    tags: ["C++", "MySQL", "SQL", "OOP", "Console UI"],
    role: ["Designed the overall game concept and storyline", "Implemented combat mechanics and game logic", "Designed and managed the database schema", "Integrated gameplay with database operations"],
    demo: "",
  },
  {
    title: "EventGo – University Activities Registration System",
    type: "Group Project (6 members) · Distributed Application Development",
    image: "https://i.imgur.com/WD0zOv5.jpg",
    problem: "Manual management of university activities causes inefficient registration, poor attendance tracking, and lack of real-time data.",
    solution: "A Java-based management system enabling administrators to publish activities, track attendance via QR codes, and analyse participation statistics.",
    tags: ["Java", "Java Swing", "Firebase", "GitHub", "QR Code"],
    role: ["Frontend developer for the admin interface", "Designed and implemented 5 Java Swing pages", "Activity Publishing & QR Code Display module", "Attendance Statistics & Backend API integration", "Collaborated using GitHub for version control"],
    demo: "https://youtu.be/GUtQEokDrrk",
  },
  {
    title: "Mushroom Identifier System",
    type: "Individual Project · Artificial Intelligence",
    image: "https://i.imgur.com/z3t59vK.jpg",
    problem: "Many people cannot identify whether a mushroom is safe to consume, posing health risks.",
    solution: "A mushroom identification system where users upload an image and receive the predicted species, confidence level, and safety advice with a user-friendly GUI.",
    tags: ["Python", "TensorFlow", "NumPy", "Pillow", "Tkinter", "Anaconda"],
    role: ["Designed the application workflow", "Built the GUI for image input and result display", "Integrated the machine learning model", "Managed Python environment and dependencies"],
    demo: "",
  },
  {
    title: "Parking Management System",
    type: "Group Project · Object-Oriented Programming",
    image: "https://i.imgur.com/RztL4mb.jpg",
    problem: "Manual parking ticket systems are inefficient and error-prone in duration calculation and payment handling.",
    solution: "A parking management system handling car and motorcycle entries, ticket printing, duration calculation, and fees at RM2/hour.",
    tags: ["Java", "OOP", "Console-based"],
    role: ["Implemented parking logic and fee calculation", "Designed the ticket workflow", "Assisted in debugging and testing"],
    demo: "https://youtu.be/4vjkTe2JH_4",
  },
];
---
<Layout title="Projects · CJJ">
<div class="page-section">

  <h1 class="page-title fade-up">Projects</h1>
  <p class="page-subtitle fade-up">Things I've built</p>

  <div class="projects-list">
    {projects.map((p, i) => (
      <div class={`glass project-card fade-up delay-${(i % 4) + 1}`}>
        {p.image && <img src={p.image} alt={p.title} class="proj-img" />}
        <div class="proj-body">
          <div class="proj-top">
            <div>
              <h2 class="proj-title">{p.title}</h2>
              <p class="proj-type">{p.type}</p>
            </div>
            {p.demo && (
              <a href={p.demo} target="_blank" rel="noopener" class="demo-btn">▶ Demo</a>
            )}
          </div>

          <div class="proj-section">
            <h3>Problem</h3>
            <p>{p.problem}</p>
          </div>
          <div class="proj-section">
            <h3>Solution</h3>
            <p>{p.solution}</p>
          </div>

          <div class="tags-row">
            {p.tags.map(t => <span class="tag">{t}</span>)}
          </div>

          <div class="proj-section">
            <h3>My Role</h3>
            <ul>
              {p.role.map(r => <li>{r}</li>)}
            </ul>
          </div>
        </div>
      </div>
    ))}
  </div>

</div>
</Layout>

<style>
  .projects-list { display: flex; flex-direction: column; gap: 2rem; }

  .project-card { overflow: hidden; }
  .proj-img { width: 100%; height: 200px; object-fit: cover; border-radius: 12px; margin-bottom: 1.2rem; }

  .proj-top { display: flex; justify-content: space-between; align-items: flex-start; gap: 1rem; margin-bottom: 1rem; flex-wrap: wrap; }
  .proj-title { font-size: 1.3rem; font-weight: 700; color: #fff; margin-bottom: 0.2rem; }
  .proj-type  { font-size: 0.8rem; color: var(--accent); font-weight: 500; }

  .demo-btn {
    padding: 0.4rem 1.2rem; border-radius: 999px; text-decoration: none;
    background: linear-gradient(135deg, var(--accent), var(--accent2));
    color: #fff; font-size: 0.82rem; font-weight: 700; flex-shrink: 0;
    transition: opacity 0.2s, transform 0.2s;
  }
  .demo-btn:hover { opacity: 0.85; transform: translateY(-2px); }

  .proj-section { margin-bottom: 0.9rem; }
  .proj-section h3 { font-size: 0.78rem; font-weight: 700; color: var(--muted); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 0.3rem; }
  .proj-section p  { font-size: 0.9rem; color: var(--muted); line-height: 1.7; }
  .proj-section ul { list-style: none; padding: 0; }
  .proj-section li { font-size: 0.88rem; color: var(--muted); padding: 0.15rem 0; }
  .proj-section li::before { content: "▸ "; color: var(--accent); }

  .tags-row { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 0.9rem; }
</style>
