---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Contact · CJJ">
<div class="page-section">

  <h1 class="page-title fade-up">Get In Touch</h1>
  <p class="page-subtitle fade-up">Open to internship opportunities — let's talk</p>

  <div class="contact-grid">

    <div class="left-col">
      <div class="glass contact-info reveal-left">
        <h2 class="card-title">Quick Contact</h2>
        <div class="contact-links">
          {[
            { icon: "✉", label: "Email", val: "danieljj03@gmail.com", href: "mailto:danieljj03@gmail.com" },
            { icon: "📞", label: "Phone", val: "+601 6556 9885",        href: "tel:+60165569885" },
            { icon: "🐙", label: "GitHub", val: "ZRBCJJ12lshsr",         href: "https://github.com/ZRBCJJ12lshsr" },
          ].map(c => (
            <a href={c.href} target={c.href.startsWith('http') ? '_blank' : '_self'} rel="noopener" class="ci-row">
              <span class="ci-icon">{c.icon}</span>
              <div>
                <p class="ci-label">{c.label}</p>
                <p class="ci-val">{c.val}</p>
              </div>
              <span class="ci-arrow">→</span>
            </a>
          ))}
        </div>
      </div>

      <div class="glass availability reveal-left">
        <div class="avail-dot"></div>
        <div>
          <p class="avail-title">Available for Internship</p>
          <p class="avail-sub">Actively looking · 2026</p>
        </div>
      </div>
    </div>

    <div class="glass contact-form reveal-right">
      <h2 class="card-title">Send Me a Message</h2>
      <form action="https://formspree.io/f/YOUR_FORM_ID" method="POST">
        <div class="form-row">
          <div class="form-group">
            <label for="name">Name *</label>
            <input type="text" id="name" name="name" placeholder="Your full name" required />
          </div>
          <div class="form-group">
            <label for="email">Email *</label>
            <input type="email" id="email" name="email" placeholder="you@example.com" required />
          </div>
        </div>
        <div class="form-group">
          <label for="subject">Subject</label>
          <input type="text" id="subject" name="subject" placeholder="Internship opportunity at..." />
        </div>
        <div class="form-group">
          <label for="message">Message *</label>
          <textarea id="message" name="message" rows="5" placeholder="Tell me about the opportunity or project..." required></textarea>
        </div>
        <button type="submit" class="btn-glow submit-btn">Send Message ✉</button>
      </form>
    </div>

  </div>
</div>
</Layout>

<style>
.contact-grid { display: grid; grid-template-columns: 1fr 1.5fr; gap: 1.5rem; align-items: start; }
@media (max-width: 720px) { .contact-grid { grid-template-columns: 1fr; } }

.left-col { display: flex; flex-direction: column; gap: 1rem; }
.card-title { font-size: 1.15rem; font-weight: 700; color: var(--cyan); margin-bottom: 1.2rem; }

.contact-links { display: flex; flex-direction: column; gap: 0.5rem; }
.ci-row {
  display: flex; align-items: center; gap: 1rem; padding: 0.75rem;
  border-radius: 10px; text-decoration: none;
  transition: background 0.2s, box-shadow 0.2s;
}
.ci-row:hover { background: rgba(0,191,165,0.08); box-shadow: 0 0 16px var(--glow-sm); }
.ci-icon  { font-size: 1.4rem; flex-shrink: 0; width: 28px; text-align: center; }
.ci-label { font-size: 0.7rem; color: var(--muted); text-transform: uppercase; letter-spacing: 1px; }
.ci-val   { font-size: 0.88rem; color: var(--cyan); font-weight: 500; }
.ci-arrow { margin-left: auto; color: var(--muted); font-size: 0.9rem; transition: transform 0.2s; }
.ci-row:hover .ci-arrow { transform: translateX(4px); color: var(--cyan); }

.availability {
  display: flex; align-items: center; gap: 1rem; padding: 1.2rem 1.5rem;
}
.avail-dot {
  width: 12px; height: 12px; border-radius: 50%; background: var(--cyan); flex-shrink: 0;
  box-shadow: 0 0 12px var(--glow);
  animation: pulse 2s ease-in-out infinite;
}
@keyframes pulse {
  0%, 100% { box-shadow: 0 0 8px var(--glow); }
  50% { box-shadow: 0 0 24px var(--glow), 0 0 8px var(--glow-sm); }
}
.avail-title { font-size: 0.9rem; font-weight: 700; color: #fff; }
.avail-sub   { font-size: 0.78rem; color: var(--muted); margin-top: 2px; }

/* Form */
.form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
@media (max-width: 480px) { .form-row { grid-template-columns: 1fr; } }

.form-group { display: flex; flex-direction: column; gap: 0.4rem; margin-bottom: 1rem; }
.form-group label { font-size: 0.8rem; color: var(--muted); font-weight: 500; }
.form-group input, .form-group textarea {
  background: rgba(0,191,165,0.04); border: 1px solid var(--border);
  border-radius: 10px; padding: 0.7rem 1rem;
  color: var(--text); font-family: inherit; font-size: 0.88rem;
  transition: border-color 0.25s, box-shadow 0.25s; resize: vertical;
}
.form-group input:focus, .form-group textarea:focus {
  outline: none; border-color: var(--cyan); box-shadow: 0 0 16px var(--glow-sm);
}
.submit-btn { width: 100%; border: none; }

.form-note { font-size: 0.75rem; color: var(--muted); margin-top: 0.8rem; line-height: 1.6; }
.form-note a { color: var(--cyan); }
.form-note code { background: rgba(0,191,165,0.1); padding: 0.1rem 0.4rem; border-radius: 4px; font-size: 0.72rem; color: var(--cyan); }
</style>
