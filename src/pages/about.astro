---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;
---
<Layout title="About · CJJ">
<div class="page-section">

  <div class="about-hero reveal">
    <div class="avatar-wrap">
      <img src="https://i.imgur.com/vsGYZ31.jpg" alt="Chai Jian Jie" class="avatar" />
      <div class="avatar-glow"></div>
    </div>
    <div class="about-intro">
      <h1 class="page-title" style="margin-bottom:0.2rem">Chai Jian Jie</h1>
      <p class="handle">@CJJ · Software Development Student</p>
      <div class="stat-chips">
        <span class="stat-chip">📍 Kuala Lumpur</span>
        <span class="stat-chip">🎂 4 Jan 2003</span>
        <span class="stat-chip">🎓 UTeM</span>
        <span class="stat-chip">🏆 CGPA 3.58</span>
      </div>
    </div>
  </div>

  <div class="glass bio-card reveal-left">
    <h2 class="card-title">Who Am I?</h2>
    <p>I'm a Software Development student at Universiti Teknikal Malaysia Melaka (UTeM), passionate about building software solutions that make a difference.</p>
    <p>Originally from Perak, I'm currently living in Kuala Lumpur and studying in Melaka. My journey in technology started with curiosity about how things work, and it has evolved into a passion for creating innovative solutions.</p>
    <p>I enjoy the challenge of transforming complex problems into elegant, user-friendly applications — whether that's developing mobile apps, building distributed systems, or exploring AI.</p>
  </div>

  <h2 class="section-h2 reveal-left">Interests & Hobbies</h2>
  <div class="hobby-grid">
    {[
      { icon: "🎮", title: "Gaming",             desc: "Strategy & adventure games fuel my problem-solving mindset" },
      { icon: "🏸", title: "Badminton",           desc: "Staying active and competitive on the court" },
      { icon: "🤝", title: "Collaboration",        desc: "Working with teams to achieve common goals" },
      { icon: "🤖", title: "AI & Tech",            desc: "Exploring AI tools and emerging technologies" },
      { icon: "📚", title: "Continuous Learning",  desc: "Always picking up new frameworks and methodologies" },
      { icon: "♟",  title: "Logic & Strategy",     desc: "Board games and puzzles to keep the mind sharp" },
    ].map((h, i) => (
      <div class={`glass hobby-card reveal d${(i%4)+1}`}>
        <span class="icon-badge hobby-badge">{h.icon}</span>
        <h3>{h.title}</h3>
        <p>{h.desc}</p>
      </div>
    ))}
  </div>

  <div class="glass goal-card reveal">
    <h2 class="card-title">Looking Forward 🚀</h2>
    <p>I'm eager to apply my skills through internships and collaborative projects. My goal is to work on meaningful software that challenges me to grow — particularly in full-stack development, mobile apps, and AI-driven applications.</p>
    <div class="goal-btns">
      <a href={`${base}projects`} class="btn-glow">See my work</a>
      <a href={`${base}contact`} class="btn-outline">Get in touch</a>
    </div>
  </div>

</div>
</Layout>

<style>
.about-hero {
  display: flex; gap: 2.5rem; align-items: center;
  margin-bottom: 2.5rem; flex-wrap: wrap;
}
.avatar-wrap { position: relative; flex-shrink: 0; }
.avatar {
  width: 150px; height: 150px; border-radius: 50%; object-fit: cover;
  border: 3px solid var(--cyan); position: relative; z-index: 1;
  box-shadow: 0 0 0 6px rgba(0,191,165,0.12);
}
.avatar-glow {
  position: absolute; inset: -12px; border-radius: 50%;
  background: radial-gradient(circle, var(--glow) 0%, transparent 70%);
  animation: pulseGlow 3s ease-in-out infinite;
}
@keyframes pulseGlow {
  0%, 100% { opacity: 0.5; transform: scale(1); }
  50% { opacity: 1; transform: scale(1.08); }
}

.handle { color: var(--cyan); font-size: 0.88rem; letter-spacing: 2px; margin-bottom: 1rem; }
.stat-chips { display: flex; flex-wrap: wrap; gap: 0.5rem; }
.stat-chip {
  padding: 0.3rem 0.9rem; border-radius: 999px; font-size: 0.8rem; font-weight: 500;
  background: rgba(0,191,165,0.08); border: 1px solid var(--border); color: var(--text);
}

.bio-card { margin-bottom: 2.5rem; }
.card-title { font-size: 1.2rem; font-weight: 700; color: var(--cyan); margin-bottom: 1rem; }
.bio-card p { color: var(--muted); line-height: 1.8; margin-bottom: 0.8rem; }
.bio-card p:last-child { margin-bottom: 0; }

.hobby-grid {
  display: grid; grid-template-columns: repeat(auto-fit, minmax(200px,1fr));
  gap: 1.1rem; margin-bottom: 2.5rem;
}
.hobby-card { text-align: center; transition: transform 0.25s; }
.hobby-card:hover { transform: translateY(-5px); }
.hobby-badge { margin: 0 auto 0.8rem; display: flex; }
.hobby-card h3 { font-size: 0.95rem; font-weight: 700; color: #fff; margin-bottom: 0.3rem; }
.hobby-card p  { font-size: 0.83rem; color: var(--muted); line-height: 1.5; }

.goal-card p { color: var(--muted); line-height: 1.8; margin-bottom: 1.5rem; }
.goal-btns { display: flex; gap: 1rem; flex-wrap: wrap; }
</style>
