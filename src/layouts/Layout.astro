---
export interface Props { title?: string; }
const { title = "CJJ Portfolio" } = Astro.props;
const base = import.meta.env.BASE_URL;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
  <!-- GSAP + ScrollTrigger -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js" defer></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js" defer></script>
</head>
<body>

  <!-- Animated ambient background -->
  <div class="bg-wrap" aria-hidden="true">
    <div class="bg-orb orb-1"></div>
    <div class="bg-orb orb-2"></div>
    <div class="bg-orb orb-3"></div>
    <div class="bg-grid"></div>
  </div>

  <!-- Navbar -->
  <nav class="navbar" id="navbar">
    <a href={`${base}`} class="nav-logo">
      <span class="logo-bracket">&lt;</span>CJJ<span class="logo-bracket">/&gt;</span>
    </a>
    <button class="nav-toggle" id="navToggle" aria-label="Menu">☰</button>
    <div class="nav-links" id="navLinks">
      <a href={`${base}`}>Home</a>
      <a href={`${base}about`}>About</a>
      <a href={`${base}academic`}>Academic</a>
      <a href={`${base}skills`}>Skills</a>
      <a href={`${base}projects`}>Projects</a>
      <a href={`${base}contact`}>Contact</a>
    </div>
  </nav>

  <main><slot /></main>

  <footer>
    <p>Crafted by <span class="footer-name">Chai Jian Jie</span> · Astro + GitHub Pages</p>
  </footer>

  <script>
    // Mobile nav
    document.getElementById('navToggle')?.addEventListener('click', () => {
      document.getElementById('navLinks')?.classList.toggle('open');
    });

    // Active link
    const path = window.location.pathname.replace(/\/$/, '') || '/';
    document.querySelectorAll('.nav-links a').forEach(a => {
      const href = (a as HTMLAnchorElement).getAttribute('href')?.replace(/\/$/, '') || '/';
      if (href === path) a.classList.add('active');
    });

    // Navbar shrink on scroll
    window.addEventListener('scroll', () => {
      document.getElementById('navbar')?.classList.toggle('scrolled', window.scrollY > 40);
    });

    // GSAP scroll reveals — runs after scripts load
    window.addEventListener('load', () => {
      if (typeof gsap === 'undefined' || typeof ScrollTrigger === 'undefined') return;
      gsap.registerPlugin(ScrollTrigger);
      gsap.utils.toArray('.reveal').forEach((el: any) => {
        gsap.fromTo(el,
          { opacity: 0, y: 40 },
          { opacity: 1, y: 0, duration: 0.7, ease: 'power2.out',
            scrollTrigger: { trigger: el, start: 'top 88%', toggleActions: 'play none none none' }
          }
        );
      });
      gsap.utils.toArray('.reveal-left').forEach((el: any) => {
        gsap.fromTo(el,
          { opacity: 0, x: -40 },
          { opacity: 1, x: 0, duration: 0.7, ease: 'power2.out',
            scrollTrigger: { trigger: el, start: 'top 88%', toggleActions: 'play none none none' }
          }
        );
      });
      gsap.utils.toArray('.reveal-right').forEach((el: any) => {
        gsap.fromTo(el,
          { opacity: 0, x: 40 },
          { opacity: 1, x: 0, duration: 0.7, ease: 'power2.out',
            scrollTrigger: { trigger: el, start: 'top 88%', toggleActions: 'play none none none' }
          }
        );
      });
    });
  </script>
</body>
</html>

<style is:global>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --cyan:     #00BFA5;
  --cyan2:    #00E5CC;
  --blue:     #0EA5E9;
  --bg:       #050d15;
  --bg2:      #091522;
  --card:     rgba(0,191,165,0.04);
  --border:   rgba(0,191,165,0.15);
  --glow:     rgba(0,191,165,0.35);
  --glow-sm:  rgba(0,191,165,0.18);
  --text:     #e2e8f0;
  --muted:    #64748b;
  --radius:   14px;
}

html { scroll-behavior: smooth; }
body {
  font-family: 'Inter', sans-serif;
  background: var(--bg);
  color: var(--text);
  min-height: 100vh;
  overflow-x: hidden;
}

/* ── Animated background ── */
.bg-wrap { position: fixed; inset: 0; z-index: 0; pointer-events: none; overflow: hidden; }

.bg-orb {
  position: absolute; border-radius: 50%;
  filter: blur(80px); opacity: 0.55; animation: drift 18s ease-in-out infinite alternate;
}
.orb-1 {
  width: 700px; height: 700px; top: -200px; left: -150px;
  background: radial-gradient(circle, rgba(0,191,165,0.4), transparent 70%);
  animation-duration: 20s;
}
.orb-2 {
  width: 500px; height: 500px; bottom: -100px; right: -100px;
  background: radial-gradient(circle, rgba(14,165,233,0.35), transparent 70%);
  animation-duration: 15s; animation-delay: -6s;
}
.orb-3 {
  width: 400px; height: 400px; top: 40%; left: 50%;
  background: radial-gradient(circle, rgba(0,229,204,0.2), transparent 70%);
  animation-duration: 25s; animation-delay: -10s;
}
@keyframes drift {
  0%   { transform: translate(0, 0) scale(1); }
  50%  { transform: translate(40px, -30px) scale(1.08); }
  100% { transform: translate(-20px, 20px) scale(0.95); }
}

.bg-grid {
  position: absolute; inset: 0;
  background-image:
    linear-gradient(rgba(0,191,165,0.04) 1px, transparent 1px),
    linear-gradient(90deg, rgba(0,191,165,0.04) 1px, transparent 1px);
  background-size: 48px 48px;
}

/* ── Navbar ── */
.navbar {
  position: fixed; top: 0; left: 0; right: 0; z-index: 100;
  display: flex; align-items: center; justify-content: space-between;
  padding: 1.1rem 2.5rem;
  transition: background 0.3s, padding 0.3s, box-shadow 0.3s;
}
.navbar.scrolled {
  background: rgba(5,13,21,0.85);
  backdrop-filter: blur(20px);
  padding: 0.7rem 2.5rem;
  box-shadow: 0 1px 0 var(--border), 0 8px 32px rgba(0,0,0,0.4);
}

.nav-logo {
  font-size: 1.3rem; font-weight: 800; text-decoration: none;
  color: var(--text); letter-spacing: 1px;
  transition: text-shadow 0.3s;
}
.nav-logo:hover { text-shadow: 0 0 20px var(--glow); }
.logo-bracket { color: var(--cyan); }

.nav-links { display: flex; gap: 2rem; }
.nav-links a {
  color: var(--muted); text-decoration: none; font-size: 0.88rem;
  font-weight: 500; transition: color 0.2s, text-shadow 0.2s;
  position: relative; padding-bottom: 3px;
}
.nav-links a::after {
  content: ''; position: absolute; bottom: -1px; left: 0; right: 0;
  height: 2px; border-radius: 1px;
  background: linear-gradient(90deg, var(--cyan), var(--blue));
  transform: scaleX(0); transform-origin: left; transition: transform 0.25s;
}
.nav-links a:hover, .nav-links a.active {
  color: var(--cyan); text-shadow: 0 0 12px var(--glow-sm);
}
.nav-links a:hover::after, .nav-links a.active::after { transform: scaleX(1); }

.nav-toggle { display: none; background: none; border: none; color: var(--text); font-size: 1.4rem; cursor: pointer; }

@media (max-width: 680px) {
  .nav-toggle { display: block; }
  .nav-links {
    display: none; flex-direction: column; gap: 1.2rem;
    position: absolute; top: 100%; left: 0; right: 0;
    background: rgba(5,13,21,0.97); padding: 1.5rem 2.5rem;
    border-bottom: 1px solid var(--border);
    backdrop-filter: blur(16px);
  }
  .nav-links.open { display: flex; }
}

/* ── Main & Footer ── */
main { position: relative; z-index: 1; padding-top: 76px; }
footer {
  position: relative; z-index: 1; text-align: center;
  padding: 2.5rem; color: var(--muted); font-size: 0.82rem;
  border-top: 1px solid var(--border);
}
.footer-name { color: var(--cyan); font-weight: 600; }

/* ── Shared page layout ── */
.page-section { max-width: 920px; margin: 0 auto; padding: 4rem 2rem 5rem; }
.page-title {
  font-size: clamp(2rem, 5vw, 3rem); font-weight: 800;
  background: linear-gradient(135deg, #fff 20%, var(--cyan) 60%, var(--blue) 100%);
  -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
  margin-bottom: 0.4rem;
}
.page-subtitle { color: var(--muted); font-size: 1rem; margin-bottom: 3rem; }
.section-h2 {
  font-size: 1.35rem; font-weight: 700; color: var(--text);
  margin: 2.5rem 0 1.2rem; display: flex; align-items: center; gap: 0.6rem;
}
.section-h2::after {
  content: ''; flex: 1; height: 1px;
  background: linear-gradient(90deg, var(--border), transparent);
}

/* ── Glass card ── */
.glass {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  backdrop-filter: blur(16px);
  padding: 1.8rem;
  transition: border-color 0.3s, box-shadow 0.3s;
}
.glass:hover {
  border-color: rgba(0,191,165,0.4);
  box-shadow: 0 0 24px var(--glow-sm), 0 8px 32px rgba(0,0,0,0.3);
}

/* ── Glow button ── */
.btn-glow {
  display: inline-block; padding: 0.75rem 2rem; border-radius: 999px;
  background: linear-gradient(135deg, var(--cyan), var(--blue));
  color: #fff; font-weight: 700; font-size: 0.9rem; text-decoration: none;
  border: none; cursor: pointer;
  box-shadow: 0 0 20px var(--glow-sm);
  transition: box-shadow 0.3s, transform 0.2s, opacity 0.2s;
}
.btn-glow:hover {
  box-shadow: 0 0 40px var(--glow), 0 4px 20px rgba(0,0,0,0.3);
  transform: translateY(-2px);
}
.btn-outline {
  display: inline-block; padding: 0.75rem 2rem; border-radius: 999px;
  border: 1px solid var(--border); color: var(--text);
  font-weight: 600; font-size: 0.9rem; text-decoration: none;
  transition: border-color 0.3s, box-shadow 0.3s, transform 0.2s, color 0.2s;
}
.btn-outline:hover {
  border-color: var(--cyan); color: var(--cyan);
  box-shadow: 0 0 20px var(--glow-sm); transform: translateY(-2px);
}

/* ── Tag pill ── */
.tag {
  display: inline-flex; align-items: center; gap: 0.3rem;
  padding: 0.25rem 0.75rem; border-radius: 999px; font-size: 0.75rem; font-weight: 600;
  background: rgba(0,191,165,0.1); color: var(--cyan);
  border: 1px solid rgba(0,191,165,0.25);
  transition: background 0.2s, box-shadow 0.2s;
}
.tag:hover { background: rgba(0,191,165,0.2); box-shadow: 0 0 12px var(--glow-sm); }

/* ── Fade animations (CSS fallback if GSAP not loaded) ── */
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(28px); }
  to   { opacity: 1; transform: translateY(0); }
}
.fade-up { animation: fadeUp 0.65s ease both; }
.d1 { animation-delay: 0.1s; } .d2 { animation-delay: 0.2s; }
.d3 { animation-delay: 0.3s; } .d4 { animation-delay: 0.4s; }
</style>
