---
export interface Props { title?: string; }
const { title = "CJJ Portfolio" } = Astro.props;
const base = import.meta.env.BASE_URL;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js" defer></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js" defer></script>
</head>
<body>

  <!-- Interactive canvas background -->
  <div class="bg-wrap" aria-hidden="true">
    <canvas id="bgCanvas"></canvas>
    <div class="bg-grid"></div>
  </div>

  <!-- Custom cyan arrow cursor (desktop only) -->
  <div id="cursorArrow" class="cursor-arrow">
    <svg width="20" height="26" viewBox="0 0 20 26" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M1 1 L1 21 L5.5 16 L8.5 23 L11 22 L8 15 L14 15 Z"
            fill="#00BFA5" stroke="#001a13" stroke-width="1.2" stroke-linejoin="round"/>
    </svg>
  </div>

  <!-- Navbar -->
  <nav class="navbar" id="navbar">
    <a href={`${base}`} class="nav-logo">CJJ</a>
    <button class="nav-toggle" id="navToggle" aria-label="Menu">&#9776;</button>
    <div class="nav-links" id="navLinks">
      <a href={`${base}`}>Home</a>
      <a href={`${base}about`}>About</a>
      <a href={`${base}academic`}>Academic</a>
      <a href={`${base}skills`}>Skills</a>
      <a href={`${base}projects`}>Projects</a>
      <a href={`${base}contact`}>Contact</a>
    </div>
  </nav>

  <main><slot /></main>

  <footer>
    <p>Crafted by <span class="footer-name">Chai Jian Jie</span> &middot; Astro + GitHub Pages</p>
  </footer>

  <script>
    document.getElementById('navToggle')?.addEventListener('click', () => {
      document.getElementById('navLinks')?.classList.toggle('open');
    });

    const path = window.location.pathname.replace(/\/$/, '') || '/';
    document.querySelectorAll('.nav-links a').forEach(a => {
      const href = (a as HTMLAnchorElement).getAttribute('href')?.replace(/\/$/, '') || '/';
      if (href === path) a.classList.add('active');
    });

    window.addEventListener('scroll', () => {
      document.getElementById('navbar')?.classList.toggle('scrolled', window.scrollY > 40);
    });

    window.addEventListener('load', () => {
      if (typeof gsap === 'undefined' || typeof ScrollTrigger === 'undefined') return;
      gsap.registerPlugin(ScrollTrigger);
      const cfg = (from: object, axis?: 'x'|'y') => ({
        ...from, opacity: 1,
        ...(axis === 'x' ? {x: 0} : {y: 0}),
        duration: 0.7, ease: 'power2.out',
      });
      gsap.utils.toArray('.reveal').forEach((el: any) =>
        gsap.fromTo(el, {opacity:0,y:40}, {...cfg({opacity:0,y:40}),
          scrollTrigger:{trigger:el,start:'top 88%',toggleActions:'play none none none'}})
      );
      gsap.utils.toArray('.reveal-left').forEach((el: any) =>
        gsap.fromTo(el, {opacity:0,x:-40}, {...cfg({opacity:0,x:-40},'x'),
          scrollTrigger:{trigger:el,start:'top 88%',toggleActions:'play none none none'}})
      );
      gsap.utils.toArray('.reveal-right').forEach((el: any) =>
        gsap.fromTo(el, {opacity:0,x:40}, {...cfg({opacity:0,x:40},'x'),
          scrollTrigger:{trigger:el,start:'top 88%',toggleActions:'play none none none'}})
      );
    });

    (function () {
      const canvas = document.getElementById('bgCanvas') as HTMLCanvasElement;
      if (!canvas) return;
      const ctx = canvas.getContext('2d')!;
      const BASE_W = 1440, BASE_H = 900;
      let W = 0, H = 0, sx = 1, sy = 1;
      const RAW_NODES = [
        [0,120],[180,40],[320,180],[80,300],
        [500,60],[650,200],[450,320],
        [850,80],[1050,150],[1200,50],[1350,220],[1440,80],
        [200,480],[400,450],[600,380],[750,480],[950,350],[1150,450],[1350,380],[1440,580],
        [100,680],[300,720],[500,650],[700,720],[900,680],[1100,720],[1300,650],
        [720,140],[280,570],[1100,570]
      ];
      type Node = {ox:number;oy:number;cx:number;cy:number};
      const nodes: Node[] = RAW_NODES.map(([ox,oy]) => ({ox,oy,cx:ox,cy:oy}));
      const HUBS = new Set([5,14,16,27]);
      const EDGES = [
        [0,1],[0,3],[1,2],[1,4],[2,3],[2,5],[2,6],[3,12],
        [4,5],[4,7],[5,6],[5,7],[5,14],[5,27],[6,13],[6,14],
        [7,8],[7,16],[7,27],[8,9],[8,10],[9,11],[10,11],[10,17],[10,18],
        [12,13],[12,20],[12,21],[12,28],[13,14],[13,22],[13,21],[13,28],
        [14,15],[14,16],[15,16],[15,22],[15,23],[16,17],[16,23],[16,24],
        [17,18],[17,24],[17,25],[17,29],[18,19],[18,25],[18,26],[19,26],
        [20,21],[21,22],[22,23],[23,24],[24,25],[25,26],[25,29],[24,29],
        [27,14],[28,20],[28,21]
      ];
      let mx = -9999, my = -9999;
      const RADIUS = 240, STRENGTH = 0.32, LERP = 0.22;
      function resize() {
        W = canvas.width = window.innerWidth;
        H = canvas.height = window.innerHeight;
        sx = W / BASE_W; sy = H / BASE_H;
      }
      document.addEventListener('mousemove', (e: MouseEvent) => { mx = e.clientX / sx; my = e.clientY / sy; });
      document.addEventListener('mouseleave', () => { mx = -9999; my = -9999; });
      const isMouse = window.matchMedia('(pointer: fine)').matches;
      function tick() {
        for (const n of nodes) {
          let tx = n.ox, ty = n.oy;
          if (isMouse && mx > -9000) {
            const dx = mx - n.ox, dy = my - n.oy;
            const dist = Math.hypot(dx, dy);
            if (dist < RADIUS) {
              const t = Math.pow(1 - dist / RADIUS, 1.6) * STRENGTH;
              tx = n.ox + dx * t; ty = n.oy + dy * t;
            }
          }
          n.cx += (tx - n.cx) * LERP;
          n.cy += (ty - n.cy) * LERP;
        }
      }
      function draw() {
        ctx.clearRect(0, 0, W, H);
        const bg = ctx.createLinearGradient(0, 0, W, H);
        bg.addColorStop(0, '#071120');
        bg.addColorStop(0.45, '#0D1B2D');
        bg.addColorStop(1, '#091528');
        ctx.fillStyle = bg; ctx.fillRect(0, 0, W, H);
        const g1 = ctx.createRadialGradient(W*.15,H*.12,0,W*.15,H*.12,W*.42);
        g1.addColorStop(0,'rgba(0,191,165,0.16)'); g1.addColorStop(1,'transparent');
        ctx.fillStyle = g1; ctx.fillRect(0,0,W,H);
        const g2 = ctx.createRadialGradient(W*.84,H*.88,0,W*.84,H*.88,W*.34);
        g2.addColorStop(0,'rgba(14,165,233,0.12)'); g2.addColorStop(1,'transparent');
        ctx.fillStyle = g2; ctx.fillRect(0,0,W,H);
        const pos = nodes.map(n => ({x: n.cx*sx, y: n.cy*sy}));
        const s = Math.min(sx, sy);
        ctx.strokeStyle = 'rgba(0,191,165,0.25)'; ctx.lineWidth = 1.6;
        for (const [a,b] of EDGES) {
          ctx.beginPath(); ctx.moveTo(pos[a].x, pos[a].y); ctx.lineTo(pos[b].x, pos[b].y); ctx.stroke();
        }
        for (let i = 0; i < nodes.length; i++) {
          const {x,y} = pos[i]; const isHub = HUBS.has(i); const r = (isHub ? 6 : 4) * s;
          ctx.beginPath(); ctx.arc(x, y, r, 0, Math.PI*2);
          ctx.fillStyle = 'rgba(0,191,165,0.55)'; ctx.fill();
          if (isHub) {
            ctx.beginPath(); ctx.arc(x, y, 11*s, 0, Math.PI*2);
            ctx.strokeStyle = 'rgba(0,191,165,0.22)'; ctx.lineWidth = 1.2; ctx.stroke();
          }
        }
      }
      function loop() { tick(); draw(); requestAnimationFrame(loop); }
      resize(); window.addEventListener('resize', resize); loop();
    })();

    (function () {
      if (!window.matchMedia('(pointer: fine)').matches) return;
      const arrow = document.getElementById('cursorArrow') as HTMLElement;
      if (!arrow) return;
      document.addEventListener('mouseenter', () => { arrow.style.opacity = '1'; });
      document.addEventListener('mouseleave', () => { arrow.style.opacity = '0'; });
      document.addEventListener('mousemove', e => {
        arrow.style.transform = `translate(${e.clientX}px, ${e.clientY}px)`;
      });
    })();
  </script>
</body>
</html>

<style is:global>

<style is:global>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --cyan:     #00BFA5;
  --cyan2:    #00E5CC;
  --blue:     #0EA5E9;
  --bg:       #071120;
  --bg2:      #0D1B2D;
  --card:     rgba(0,191,165,0.04);
  --border:   rgba(0,191,165,0.15);
  --glow:     rgba(0,191,165,0.35);
  --glow-sm:  rgba(0,191,165,0.18);
  --text:     #e2e8f0;
  --muted:    #64748b;
  --radius:   14px;
}

html { scroll-behavior: smooth; }
body {
  font-family: 'Inter', sans-serif;
  background: var(--bg);
  color: var(--text);
  min-height: 100vh;
  overflow-x: hidden;
}

.bg-wrap {
  position: fixed; inset: 0; z-index: 0;
  pointer-events: none; overflow: hidden;
}
#bgCanvas { position: absolute; inset: 0; width: 100%; height: 100%; }
.bg-grid {
  position: absolute; inset: 0;
  background-image:
    linear-gradient(rgba(0,191,165,0.03) 1px, transparent 1px),
    linear-gradient(90deg, rgba(0,191,165,0.03) 1px, transparent 1px);
  background-size: 60px 60px;
}

.cursor-arrow {
  position: fixed; top: 0; left: 0;
  pointer-events: none; z-index: 9999;
  will-change: transform;
  filter: drop-shadow(0 0 3px rgba(0,191,165,0.85)) drop-shadow(0 0 8px rgba(0,191,165,0.42));
  transition: opacity 0.15s;
  transform: translate(0, 0);
}
@media (pointer: coarse) { .cursor-arrow { display: none; } }
@media (pointer: fine) { *, *::before, *::after { cursor: none !important; } }

.navbar {
  position: fixed; top: 0; left: 0; right: 0; z-index: 100;
  display: flex; align-items: center; justify-content: space-between;
  padding: 1.1rem 2.5rem;
  transition: background 0.3s, padding 0.3s, box-shadow 0.3s;
}
.navbar.scrolled {
  background: rgba(7,17,32,0.88);
  backdrop-filter: blur(20px);
  padding: 0.7rem 2.5rem;
  box-shadow: 0 1px 0 var(--border), 0 8px 32px rgba(0,0,0,0.4);
}
.nav-logo {
  font-size: 1.3rem; font-weight: 800; text-decoration: none;
  color: var(--cyan); letter-spacing: 2px;
  text-shadow: 0 0 16px rgba(0,191,165,0.4);
  transition: text-shadow 0.3s;
}
.nav-logo:hover { text-shadow: 0 0 28px rgba(0,191,165,0.7); }
.nav-links { display: flex; gap: 2rem; }
.nav-links a {
  color: var(--muted); text-decoration: none; font-size: 0.88rem;
  font-weight: 500; transition: color 0.2s, text-shadow 0.2s;
  position: relative; padding-bottom: 3px;
}
.nav-links a::after {
  content: ''; position: absolute; bottom: -1px; left: 0; right: 0;
  height: 2px; border-radius: 1px;
  background: linear-gradient(90deg, var(--cyan), var(--blue));
  transform: scaleX(0); transform-origin: left; transition: transform 0.25s;
}
.nav-links a:hover, .nav-links a.active { color: var(--cyan); text-shadow: 0 0 12px var(--glow-sm); }
.nav-links a:hover::after, .nav-links a.active::after { transform: scaleX(1); }
.nav-toggle { display: none; background: none; border: none; color: var(--text); font-size: 1.4rem; }

@media (max-width: 680px) {
  .nav-toggle { display: block; }
  .nav-links {
    display: none; flex-direction: column; gap: 1.2rem;
    position: absolute; top: 100%; left: 0; right: 0;
    background: rgba(7,17,32,0.97); padding: 1.5rem 2.5rem;
    border-bottom: 1px solid var(--border); backdrop-filter: blur(16px);
  }
  .nav-links.open { display: flex; }
}

main { position: relative; z-index: 1; padding-top: 76px; isolation: isolate; }
footer {
  position: relative; z-index: 1; text-align: center;
  padding: 2.5rem; color: var(--muted); font-size: 0.82rem;
  border-top: 1px solid var(--border);
}
.footer-name { color: var(--cyan); font-weight: 600; }

.page-section { max-width: 920px; margin: 0 auto; padding: 4rem 2rem 5rem; }
.page-title {
  font-size: clamp(2rem, 5vw, 3rem); font-weight: 800;
  background: linear-gradient(135deg, #fff 20%, var(--cyan) 60%, var(--blue) 100%);
  -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
  margin-bottom: 0.4rem;
}
.page-subtitle { color: var(--muted); font-size: 1rem; margin-bottom: 3rem; }
.section-h2 {
  font-size: 1.35rem; font-weight: 700; color: var(--text);
  margin: 2.5rem 0 1.2rem; display: flex; align-items: center; gap: 0.6rem;
}
.section-h2::after {
  content: ''; flex: 1; height: 1px;
  background: linear-gradient(90deg, var(--border), transparent);
}

.glass {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  backdrop-filter: blur(16px);
  padding: 1.8rem;
  position: relative; z-index: 1;
  box-shadow:
    0 0 0 1px rgba(0,191,165,0.08),
    0 0 30px rgba(0,191,165,0.20),
    0 0 72px rgba(0,191,165,0.07),
    inset 0 0 32px rgba(0,191,165,0.04);
  transition: border-color 0.4s, box-shadow 0.4s;
}
.glass::after {
  content: '';
  position: absolute; inset: -2px;
  border-radius: calc(var(--radius) + 2px);
  border: 1px solid rgba(0,191,165,0);
  pointer-events: none;
  transition: border-color 0.4s, box-shadow 0.4s;
}
.glass:hover {
  border-color: rgba(0,191,165,0.60);
  box-shadow:
    0 0 52px rgba(0,191,165,0.48),
    0 0 110px rgba(0,191,165,0.20),
    0 0 180px rgba(0,191,165,0.07),
    0 10px 40px rgba(0,0,0,0.5),
    inset 0 0 40px rgba(0,191,165,0.08);
}
.glass:hover::after {
  border-color: rgba(0,191,165,0.35);
  box-shadow: 0 0 24px rgba(0,191,165,0.30);
  animation: glowRingPulse 2s ease-in-out infinite;
}
@keyframes glowRingPulse {
  0%, 100% { border-color: rgba(0,191,165,0.22); box-shadow: 0 0 18px rgba(0,191,165,0.20); }
  50%       { border-color: rgba(0,191,165,0.60); box-shadow: 0 0 52px rgba(0,191,165,0.52); }
}
.glass:hover .icon-badge {
  transform: scale(1.15);
  box-shadow: 0 0 22px rgba(0,191,165,0.52), 0 0 8px rgba(14,165,233,0.30), inset 0 1px 0 rgba(255,255,255,0.12);
}

.icon-badge {
  display: inline-flex; align-items: center; justify-content: center;
  width: 54px; height: 54px; border-radius: 14px;
  background: linear-gradient(135deg, rgba(0,191,165,0.18) 0%, rgba(14,165,233,0.12) 100%);
  border: 1px solid rgba(0,191,165,0.22); font-size: 1.65rem;
  box-shadow: 0 0 12px rgba(0,191,165,0.10), inset 0 1px 0 rgba(255,255,255,0.06);
  transition: transform 0.3s cubic-bezier(0.34,1.56,0.64,1), box-shadow 0.3s;
  flex-shrink: 0;
}

.btn-glow {
  display: inline-block; padding: 0.75rem 2rem; border-radius: 999px;
  background: linear-gradient(135deg, var(--cyan), var(--blue));
  color: #fff; font-weight: 700; font-size: 0.9rem; text-decoration: none;
  border: none;
  box-shadow: 0 0 20px var(--glow-sm);
  transition: box-shadow 0.3s, transform 0.2s;
}
.btn-glow:hover { box-shadow: 0 0 40px var(--glow), 0 4px 20px rgba(0,0,0,0.3); transform: translateY(-2px); }
.btn-outline {
  display: inline-block; padding: 0.75rem 2rem; border-radius: 999px;
  border: 1px solid var(--border); color: var(--text);
  font-weight: 600; font-size: 0.9rem; text-decoration: none;
  transition: border-color 0.3s, box-shadow 0.3s, transform 0.2s, color 0.2s;
}
.btn-outline:hover { border-color: var(--cyan); color: var(--cyan); box-shadow: 0 0 20px var(--glow-sm); transform: translateY(-2px); }

.tag {
  display: inline-flex; align-items: center; gap: 0.3rem;
  padding: 0.25rem 0.75rem; border-radius: 999px; font-size: 0.75rem; font-weight: 600;
  background: rgba(0,191,165,0.1); color: var(--cyan);
  border: 1px solid rgba(0,191,165,0.25);
  transition: background 0.2s, box-shadow 0.2s;
}
.tag:hover { background: rgba(0,191,165,0.2); box-shadow: 0 0 12px var(--glow-sm); }

img.tool-icon[alt="GitHub"], img.tag-icon[alt="GitHub"] { filter: brightness(0) invert(0.85); }

@keyframes fadeUp { from { opacity:0; transform:translateY(28px); } to { opacity:1; transform:translateY(0); } }
.fade-up { animation: fadeUp 0.65s ease both; }
.d1 { animation-delay:0.1s; } .d2 { animation-delay:0.2s; }
.d3 { animation-delay:0.3s; } .d4 { animation-delay:0.4s; }
</style>
