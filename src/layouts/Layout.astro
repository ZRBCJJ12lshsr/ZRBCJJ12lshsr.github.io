---
export interface Props {
  title?: string;
}
const { title = "CJJ Portfolio" } = Astro.props;
const base = import.meta.env.BASE_URL;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
</head>
<body>

  <!-- Ambient background (always visible beneath page content) -->
  <div class="bg-ambient"></div>

  <!-- Navigation -->
  <nav class="navbar">
    <a href={`${base}`} class="nav-logo">CJJ</a>
    <button class="nav-toggle" id="navToggle" aria-label="Toggle menu">☰</button>
    <div class="nav-links" id="navLinks">
      <a href={`${base}`}>Home</a>
      <a href={`${base}about`}>About</a>
      <a href={`${base}academic`}>Academic</a>
      <a href={`${base}skills`}>Skills</a>
      <a href={`${base}projects`}>Projects</a>
      <a href={`${base}contact`}>Contact</a>
    </div>
  </nav>

  <main>
    <slot />
  </main>

  <footer>
    <p>© 2025 Chai Jian Jie · Built with Astro · Hosted on GitHub Pages</p>
  </footer>

  <script>
    // Mobile nav toggle
    const toggle = document.getElementById('navToggle');
    const links  = document.getElementById('navLinks');
    toggle?.addEventListener('click', () => links?.classList.toggle('open'));

    // Highlight active nav link
    const path = window.location.pathname.replace(/\/$/, '') || '/';
    document.querySelectorAll('.nav-links a').forEach(a => {
      const href = (a as HTMLAnchorElement).getAttribute('href')?.replace(/\/$/, '') || '/';
      if (href === path) a.classList.add('active');
    });
  </script>
</body>
</html>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --accent:   #a78bfa;
    --accent2:  #ec4899;
    --teal:     #2dd4bf;
    --bg:       #0a0a14;
    --card:     rgba(255,255,255,0.05);
    --border:   rgba(255,255,255,0.1);
    --text:     #e2e8f0;
    --muted:    #94a3b8;
    --radius:   16px;
  }

  html { scroll-behavior: smooth; }

  body {
    font-family: 'Inter', sans-serif;
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* Ambient purple-pink gradient background */
  .bg-ambient {
    position: fixed; inset: 0; z-index: 0; pointer-events: none;
    background:
      radial-gradient(ellipse 80% 60% at 20% 10%, rgba(139,92,246,0.25) 0%, transparent 60%),
      radial-gradient(ellipse 60% 50% at 80% 80%, rgba(236,72,153,0.2) 0%, transparent 55%),
      radial-gradient(ellipse 50% 40% at 50% 50%, rgba(45,212,191,0.08) 0%, transparent 60%),
      #0a0a14;
  }

  /* ── Navbar ── */
  .navbar {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    display: flex; align-items: center; justify-content: space-between;
    padding: 1rem 2rem;
    background: rgba(10,10,20,0.7);
    backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--border);
  }
  .nav-logo {
    font-size: 1.4rem; font-weight: 700; color: var(--accent);
    text-decoration: none; letter-spacing: 2px;
  }
  .nav-links { display: flex; gap: 1.8rem; }
  .nav-links a {
    color: var(--muted); text-decoration: none; font-size: 0.9rem;
    font-weight: 500; transition: color 0.2s;
    position: relative; padding-bottom: 2px;
  }
  .nav-links a::after {
    content: ''; position: absolute; bottom: -2px; left: 0; right: 0;
    height: 2px; background: linear-gradient(90deg, var(--accent), var(--accent2));
    transform: scaleX(0); transition: transform 0.2s;
  }
  .nav-links a:hover, .nav-links a.active { color: var(--text); }
  .nav-links a:hover::after, .nav-links a.active::after { transform: scaleX(1); }

  .nav-toggle { display: none; background: none; border: none; color: var(--text); font-size: 1.4rem; cursor: pointer; }

  @media (max-width: 640px) {
    .nav-toggle { display: block; }
    .nav-links {
      display: none; flex-direction: column; gap: 1rem;
      position: absolute; top: 100%; left: 0; right: 0;
      background: rgba(10,10,20,0.95); padding: 1.5rem 2rem;
      border-bottom: 1px solid var(--border);
    }
    .nav-links.open { display: flex; }
  }

  /* ── Main & Footer ── */
  main { position: relative; z-index: 1; padding-top: 72px; }

  footer {
    position: relative; z-index: 1;
    text-align: center; padding: 2rem;
    color: var(--muted); font-size: 0.8rem;
    border-top: 1px solid var(--border);
  }

  /* ── Shared section styles ── */
  .page-section {
    max-width: 900px; margin: 0 auto; padding: 4rem 2rem;
  }
  .page-title {
    font-size: clamp(2rem, 5vw, 3rem); font-weight: 700;
    background: linear-gradient(135deg, var(--accent), var(--accent2));
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    background-clip: text; margin-bottom: 0.5rem;
  }
  .page-subtitle {
    color: var(--muted); font-size: 1rem; margin-bottom: 3rem;
  }

  /* ── Glass card ── */
  .glass {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    backdrop-filter: blur(12px);
    padding: 1.8rem;
  }

  /* ── Tag pill ── */
  .tag {
    display: inline-block; padding: 0.25rem 0.75rem; border-radius: 999px;
    font-size: 0.75rem; font-weight: 600;
    background: rgba(167,139,250,0.15); color: var(--accent);
    border: 1px solid rgba(167,139,250,0.3);
  }

  /* ── Fade-in animation ── */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .fade-up { animation: fadeUp 0.6s ease both; }
  .delay-1 { animation-delay: 0.1s; }
  .delay-2 { animation-delay: 0.2s; }
  .delay-3 { animation-delay: 0.3s; }
  .delay-4 { animation-delay: 0.4s; }
</style>
