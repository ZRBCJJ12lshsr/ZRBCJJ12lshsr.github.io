---
export interface Props { title?: string; }
const { title = "CJJ Portfolio" } = Astro.props;
const base = import.meta.env.BASE_URL;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
  <!-- GSAP + ScrollTrigger -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js" defer></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js" defer></script>
</head>
<body>

  <!-- Static polygon network background -->
  <div class="bg-wrap" aria-hidden="true">
    <svg class="bg-network" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1440 900" preserveAspectRatio="xMidYMid slice">
      <defs>
        <linearGradient id="bgGrad" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%"   stop-color="#071120" />
          <stop offset="45%"  stop-color="#0D1B2D" />
          <stop offset="100%" stop-color="#091528" />
        </linearGradient>
        <radialGradient id="glowTL" cx="15%" cy="12%" r="38%">
          <stop offset="0%"   stop-color="rgba(0,191,165,0.14)" />
          <stop offset="100%" stop-color="transparent" stop-opacity="0" />
        </radialGradient>
        <radialGradient id="glowBR" cx="82%" cy="88%" r="32%">
          <stop offset="0%"   stop-color="rgba(14,165,233,0.10)" />
          <stop offset="100%" stop-color="transparent" stop-opacity="0" />
        </radialGradient>
      </defs>

      <!-- Base gradient fill -->
      <rect width="1440" height="900" fill="url(#bgGrad)" />
      <!-- Ambient corner glows -->
      <rect width="1440" height="900" fill="url(#glowTL)" />
      <rect width="1440" height="900" fill="url(#glowBR)" />

      <!-- Polygon network lines -->
      <g stroke="rgba(0,191,165,0.13)" stroke-width="1" fill="none">
        <!-- top-left cluster -->
        <line x1="0"    y1="120" x2="180"  y2="40"  />
        <line x1="0"    y1="120" x2="80"   y2="300" />
        <line x1="180"  y1="40"  x2="320"  y2="180" />
        <line x1="180"  y1="40"  x2="500"  y2="60"  />
        <line x1="320"  y1="180" x2="80"   y2="300" />
        <line x1="320"  y1="180" x2="650"  y2="200" />
        <line x1="320"  y1="180" x2="450"  y2="320" />
        <line x1="80"   y1="300" x2="200"  y2="480" />
        <!-- top-center cluster -->
        <line x1="500"  y1="60"  x2="650"  y2="200" />
        <line x1="500"  y1="60"  x2="850"  y2="80"  />
        <line x1="650"  y1="200" x2="450"  y2="320" />
        <line x1="650"  y1="200" x2="850"  y2="80"  />
        <line x1="650"  y1="200" x2="600"  y2="380" />
        <line x1="450"  y1="320" x2="400"  y2="450" />
        <line x1="450"  y1="320" x2="600"  y2="380" />
        <!-- top-right cluster -->
        <line x1="850"  y1="80"  x2="1050" y2="150" />
        <line x1="850"  y1="80"  x2="950"  y2="350" />
        <line x1="1050" y1="150" x2="1200" y2="50"  />
        <line x1="1050" y1="150" x2="1350" y2="220" />
        <line x1="1200" y1="50"  x2="1440" y2="80"  />
        <line x1="1350" y1="220" x2="1440" y2="80"  />
        <line x1="1350" y1="220" x2="1150" y2="450" />
        <line x1="1350" y1="220" x2="1350" y2="380" />
        <!-- mid-left cluster -->
        <line x1="200"  y1="480" x2="400"  y2="450" />
        <line x1="200"  y1="480" x2="100"  y2="680" />
        <line x1="200"  y1="480" x2="300"  y2="720" />
        <line x1="400"  y1="450" x2="600"  y2="380" />
        <line x1="400"  y1="450" x2="500"  y2="650" />
        <line x1="400"  y1="450" x2="300"  y2="720" />
        <!-- mid-center cluster -->
        <line x1="600"  y1="380" x2="750"  y2="480" />
        <line x1="600"  y1="380" x2="950"  y2="350" />
        <line x1="750"  y1="480" x2="950"  y2="350" />
        <line x1="750"  y1="480" x2="700"  y2="720" />
        <line x1="750"  y1="480" x2="500"  y2="650" />
        <!-- mid-right cluster -->
        <line x1="950"  y1="350" x2="1150" y2="450" />
        <line x1="950"  y1="350" x2="900"  y2="680" />
        <line x1="1150" y1="450" x2="1350" y2="380" />
        <line x1="1150" y1="450" x2="1100" y2="720" />
        <line x1="1150" y1="450" x2="900"  y2="680" />
        <line x1="1350" y1="380" x2="1440" y2="580" />
        <line x1="1350" y1="380" x2="1300" y2="650" />
        <!-- bottom row -->
        <line x1="100"  y1="680" x2="300"  y2="720" />
        <line x1="300"  y1="720" x2="500"  y2="650" />
        <line x1="500"  y1="650" x2="700"  y2="720" />
        <line x1="700"  y1="720" x2="900"  y2="680" />
        <line x1="900"  y1="680" x2="1100" y2="720" />
        <line x1="1100" y1="720" x2="1300" y2="650" />
        <line x1="1300" y1="650" x2="1440" y2="580" />
      </g>

      <!-- Network vertex dots -->
      <g fill="rgba(0,191,165,0.30)">
        <circle cx="0"    cy="120" r="2.5" />
        <circle cx="180"  cy="40"  r="2.5" />
        <circle cx="320"  cy="180" r="3"   />
        <circle cx="80"   cy="300" r="2.5" />
        <circle cx="500"  cy="60"  r="2.5" />
        <circle cx="650"  cy="200" r="3.5" />
        <circle cx="450"  cy="320" r="2.5" />
        <circle cx="850"  cy="80"  r="3"   />
        <circle cx="1050" cy="150" r="2.5" />
        <circle cx="1200" cy="50"  r="2.5" />
        <circle cx="1350" cy="220" r="3"   />
        <circle cx="1440" cy="80"  r="2"   />
        <circle cx="200"  cy="480" r="3"   />
        <circle cx="400"  cy="450" r="3"   />
        <circle cx="600"  cy="380" r="3.5" />
        <circle cx="750"  cy="480" r="2.5" />
        <circle cx="950"  cy="350" r="3"   />
        <circle cx="1150" cy="450" r="3"   />
        <circle cx="1350" cy="380" r="2.5" />
        <circle cx="1440" cy="580" r="2"   />
        <circle cx="100"  cy="680" r="2.5" />
        <circle cx="300"  cy="720" r="2.5" />
        <circle cx="500"  cy="650" r="3"   />
        <circle cx="700"  cy="720" r="2.5" />
        <circle cx="900"  cy="680" r="3"   />
        <circle cx="1100" cy="720" r="2.5" />
        <circle cx="1300" cy="650" r="2.5" />
      </g>

      <!-- Larger glowing halo rings at key hub nodes -->
      <g fill="none" stroke="rgba(0,191,165,0.18)" stroke-width="1">
        <circle cx="650"  cy="200" r="6" />
        <circle cx="600"  cy="380" r="6" />
        <circle cx="950"  cy="350" r="6" />
      </g>
    </svg>

    <!-- Subtle dot-grid overlay -->
    <div class="bg-grid"></div>
  </div>

  <!-- Navbar -->
  <nav class="navbar" id="navbar">
    <a href={`${base}`} class="nav-logo">
      <span class="logo-bracket">&lt;</span>CJJ<span class="logo-bracket">/&gt;</span>
    </a>
    <button class="nav-toggle" id="navToggle" aria-label="Menu">☰</button>
    <div class="nav-links" id="navLinks">
      <a href={`${base}`}>Home</a>
      <a href={`${base}about`}>About</a>
      <a href={`${base}academic`}>Academic</a>
      <a href={`${base}skills`}>Skills</a>
      <a href={`${base}projects`}>Projects</a>
      <a href={`${base}contact`}>Contact</a>
    </div>
  </nav>

  <main><slot /></main>

  <footer>
    <p>Crafted by <span class="footer-name">Chai Jian Jie</span> · Astro + GitHub Pages</p>
  </footer>

  <script>
    // Mobile nav
    document.getElementById('navToggle')?.addEventListener('click', () => {
      document.getElementById('navLinks')?.classList.toggle('open');
    });

    // Active link
    const path = window.location.pathname.replace(/\/$/, '') || '/';
    document.querySelectorAll('.nav-links a').forEach(a => {
      const href = (a as HTMLAnchorElement).getAttribute('href')?.replace(/\/$/, '') || '/';
      if (href === path) a.classList.add('active');
    });

    // Navbar shrink on scroll
    window.addEventListener('scroll', () => {
      document.getElementById('navbar')?.classList.toggle('scrolled', window.scrollY > 40);
    });

    // GSAP scroll reveals — runs after scripts load
    window.addEventListener('load', () => {
      if (typeof gsap === 'undefined' || typeof ScrollTrigger === 'undefined') return;
      gsap.registerPlugin(ScrollTrigger);
      gsap.utils.toArray('.reveal').forEach((el: any) => {
        gsap.fromTo(el,
          { opacity: 0, y: 40 },
          { opacity: 1, y: 0, duration: 0.7, ease: 'power2.out',
            scrollTrigger: { trigger: el, start: 'top 88%', toggleActions: 'play none none none' }
          }
        );
      });
      gsap.utils.toArray('.reveal-left').forEach((el: any) => {
        gsap.fromTo(el,
          { opacity: 0, x: -40 },
          { opacity: 1, x: 0, duration: 0.7, ease: 'power2.out',
            scrollTrigger: { trigger: el, start: 'top 88%', toggleActions: 'play none none none' }
          }
        );
      });
      gsap.utils.toArray('.reveal-right').forEach((el: any) => {
        gsap.fromTo(el,
          { opacity: 0, x: 40 },
          { opacity: 1, x: 0, duration: 0.7, ease: 'power2.out',
            scrollTrigger: { trigger: el, start: 'top 88%', toggleActions: 'play none none none' }
          }
        );
      });
    });
  </script>
</body>
</html>

<style is:global>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --cyan:     #00BFA5;
  --cyan2:    #00E5CC;
  --blue:     #0EA5E9;
  --bg:       #071120;
  --bg2:      #0D1B2D;
  --card:     rgba(0,191,165,0.04);
  --border:   rgba(0,191,165,0.15);
  --glow:     rgba(0,191,165,0.35);
  --glow-sm:  rgba(0,191,165,0.18);
  --text:     #e2e8f0;
  --muted:    #64748b;
  --radius:   14px;
}

html { scroll-behavior: smooth; }
body {
  font-family: 'Inter', sans-serif;
  background: var(--bg);
  color: var(--text);
  min-height: 100vh;
  overflow-x: hidden;
}

/* ── Static polygon network background ── */
.bg-wrap {
  position: fixed; inset: 0; z-index: 0;
  pointer-events: none; overflow: hidden;
}
.bg-network {
  position: absolute; inset: 0;
  width: 100%; height: 100%;
}
.bg-grid {
  position: absolute; inset: 0;
  background-image:
    linear-gradient(rgba(0,191,165,0.03) 1px, transparent 1px),
    linear-gradient(90deg, rgba(0,191,165,0.03) 1px, transparent 1px);
  background-size: 60px 60px;
}

/* ── Navbar ── */
.navbar {
  position: fixed; top: 0; left: 0; right: 0; z-index: 100;
  display: flex; align-items: center; justify-content: space-between;
  padding: 1.1rem 2.5rem;
  transition: background 0.3s, padding 0.3s, box-shadow 0.3s;
}
.navbar.scrolled {
  background: rgba(7,17,32,0.88);
  backdrop-filter: blur(20px);
  padding: 0.7rem 2.5rem;
  box-shadow: 0 1px 0 var(--border), 0 8px 32px rgba(0,0,0,0.4);
}

.nav-logo {
  font-size: 1.3rem; font-weight: 800; text-decoration: none;
  color: var(--text); letter-spacing: 1px;
  transition: text-shadow 0.3s;
}
.nav-logo:hover { text-shadow: 0 0 20px var(--glow); }
.logo-bracket { color: var(--cyan); }

.nav-links { display: flex; gap: 2rem; }
.nav-links a {
  color: var(--muted); text-decoration: none; font-size: 0.88rem;
  font-weight: 500; transition: color 0.2s, text-shadow 0.2s;
  position: relative; padding-bottom: 3px;
}
.nav-links a::after {
  content: ''; position: absolute; bottom: -1px; left: 0; right: 0;
  height: 2px; border-radius: 1px;
  background: linear-gradient(90deg, var(--cyan), var(--blue));
  transform: scaleX(0); transform-origin: left; transition: transform 0.25s;
}
.nav-links a:hover, .nav-links a.active {
  color: var(--cyan); text-shadow: 0 0 12px var(--glow-sm);
}
.nav-links a:hover::after, .nav-links a.active::after { transform: scaleX(1); }

.nav-toggle { display: none; background: none; border: none; color: var(--text); font-size: 1.4rem; cursor: pointer; }

@media (max-width: 680px) {
  .nav-toggle { display: block; }
  .nav-links {
    display: none; flex-direction: column; gap: 1.2rem;
    position: absolute; top: 100%; left: 0; right: 0;
    background: rgba(7,17,32,0.97); padding: 1.5rem 2.5rem;
    border-bottom: 1px solid var(--border);
    backdrop-filter: blur(16px);
  }
  .nav-links.open { display: flex; }
}

/* ── Main & Footer ── */
main { position: relative; z-index: 1; padding-top: 76px; }
footer {
  position: relative; z-index: 1; text-align: center;
  padding: 2.5rem; color: var(--muted); font-size: 0.82rem;
  border-top: 1px solid var(--border);
}
.footer-name { color: var(--cyan); font-weight: 600; }

/* ── Shared page layout ── */
.page-section { max-width: 920px; margin: 0 auto; padding: 4rem 2rem 5rem; }
.page-title {
  font-size: clamp(2rem, 5vw, 3rem); font-weight: 800;
  background: linear-gradient(135deg, #fff 20%, var(--cyan) 60%, var(--blue) 100%);
  -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
  margin-bottom: 0.4rem;
}
.page-subtitle { color: var(--muted); font-size: 1rem; margin-bottom: 3rem; }
.section-h2 {
  font-size: 1.35rem; font-weight: 700; color: var(--text);
  margin: 2.5rem 0 1.2rem; display: flex; align-items: center; gap: 0.6rem;
}
.section-h2::after {
  content: ''; flex: 1; height: 1px;
  background: linear-gradient(90deg, var(--border), transparent);
}

/* ── Glass card — static outer glow, dynamic on hover ── */
.glass {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  backdrop-filter: blur(16px);
  padding: 1.8rem;
  /* static ambient glow always visible */
  box-shadow:
    0 0 0 1px rgba(0,191,165,0.05),
    0 0 18px rgba(0,191,165,0.07),
    inset 0 0 24px rgba(0,191,165,0.02);
  transition: border-color 0.3s, box-shadow 0.3s;
}
.glass:hover {
  border-color: rgba(0,191,165,0.45);
  /* dynamic glow on hover */
  box-shadow:
    0 0 28px rgba(0,191,165,0.22),
    0 0 60px rgba(0,191,165,0.09),
    0 8px 32px rgba(0,0,0,0.4),
    inset 0 0 24px rgba(0,191,165,0.04);
}
/* Icon badge grows on card hover */
.glass:hover .icon-badge {
  transform: scale(1.15);
  box-shadow:
    0 0 18px rgba(0,191,165,0.45),
    0 0 8px rgba(14,165,233,0.25),
    inset 0 1px 0 rgba(255,255,255,0.1);
}

/* ── Icon badge — iOS curved-square style ── */
.icon-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 54px;
  height: 54px;
  border-radius: 14px;
  background: linear-gradient(135deg, rgba(0,191,165,0.18) 0%, rgba(14,165,233,0.12) 100%);
  border: 1px solid rgba(0,191,165,0.22);
  font-size: 1.65rem;
  box-shadow:
    0 0 12px rgba(0,191,165,0.10),
    inset 0 1px 0 rgba(255,255,255,0.06);
  transition: transform 0.3s cubic-bezier(0.34,1.56,0.64,1), box-shadow 0.3s;
  flex-shrink: 0;
}

/* ── Glow button ── */
.btn-glow {
  display: inline-block; padding: 0.75rem 2rem; border-radius: 999px;
  background: linear-gradient(135deg, var(--cyan), var(--blue));
  color: #fff; font-weight: 700; font-size: 0.9rem; text-decoration: none;
  border: none; cursor: pointer;
  box-shadow: 0 0 20px var(--glow-sm);
  transition: box-shadow 0.3s, transform 0.2s, opacity 0.2s;
}
.btn-glow:hover {
  box-shadow: 0 0 40px var(--glow), 0 4px 20px rgba(0,0,0,0.3);
  transform: translateY(-2px);
}
.btn-outline {
  display: inline-block; padding: 0.75rem 2rem; border-radius: 999px;
  border: 1px solid var(--border); color: var(--text);
  font-weight: 600; font-size: 0.9rem; text-decoration: none;
  transition: border-color 0.3s, box-shadow 0.3s, transform 0.2s, color 0.2s;
}
.btn-outline:hover {
  border-color: var(--cyan); color: var(--cyan);
  box-shadow: 0 0 20px var(--glow-sm); transform: translateY(-2px);
}

/* ── Tag pill ── */
.tag {
  display: inline-flex; align-items: center; gap: 0.3rem;
  padding: 0.25rem 0.75rem; border-radius: 999px; font-size: 0.75rem; font-weight: 600;
  background: rgba(0,191,165,0.1); color: var(--cyan);
  border: 1px solid rgba(0,191,165,0.25);
  transition: background 0.2s, box-shadow 0.2s;
}
.tag:hover { background: rgba(0,191,165,0.2); box-shadow: 0 0 12px var(--glow-sm); }

/* ── Dark devicons: make visible on dark bg ── */
img.tool-icon[alt="GitHub"],
img.tag-icon[alt="GitHub"] {
  filter: brightness(0) invert(0.85);
}

/* ── Fade animations (CSS fallback if GSAP not loaded) ── */
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(28px); }
  to   { opacity: 1; transform: translateY(0); }
}
.fade-up { animation: fadeUp 0.65s ease both; }
.d1 { animation-delay: 0.1s; } .d2 { animation-delay: 0.2s; }
.d3 { animation-delay: 0.3s; } .d4 { animation-delay: 0.4s; }
</style>
